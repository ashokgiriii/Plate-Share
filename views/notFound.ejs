<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <title><%= title %></title>
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <meta content="" name="keywords">
  <meta content="<%= message %>" name="description">
  <%- include('config/export') %>
</head>

<body>
  <div class="container-xxl bg-white p-0">
    <div class="container-xxl position-relative p-0">
      <%- include('config/nav') %>

      <div class="container-xxl py-5 bg-dark hero-header mb-5">
        <div class="container text-center my-5 pt-5 pb-4">
          <h1 class="display-3 text-white mb-3 animated slideInDown"><%= heroTitle %></h1>
        </div>
      </div>
    </div>

    <main class="container-xxl py-5">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-7 text-center">
            <div class="mb-4">
              <span class="display-1 fw-bold text-primary">404</span>
            </div>
            <h2 class="mb-3"><%= heading %></h2>
            <p class="text-muted mb-4"><%= message %></p>
            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
              <a href="<%= buttonLink %>" class="btn btn-primary py-3 px-5"><%= buttonText %></a>
              <a href="<%= secondaryButtonLink %>" class="btn btn-outline-primary py-3 px-5"><%= secondaryButtonText %></a>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('config/footer') %>
  </div>
</body>

</html>
