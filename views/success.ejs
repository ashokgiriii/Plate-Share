<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <title><%= title %></title>
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <meta content="" name="keywords">
  <meta content="" name="description">
  <%- include('config/export') %>
</head>

<body>
  <div class="container-xxl bg-white p-0">
    <%- include('config/nav') %>

    <div class="container-xxl py-5 bg-dark hero-header mb-5">
      <div class="container text-center my-5 pt-5 pb-4">
        <h1 class="display-3 text-white mb-3 animated slideInDown"><%= heroTitle %></h1>
      </div>
    </div>

    <div class="container my-5">
      <div class="row justify-content-center">
        <div class="col-md-8">
          <div class="card shadow border-start border-5 border-success p-4">
            <div class="text-center">
              <img src="https://img.icons8.com/flat-round/64/000000/checkmark.png" alt="Success Icon" class="mb-3">
              <h2 class="text-success"><%= heading %></h2>
              <p><%= message %></p>
              <p class="text-muted"><%= subMessage %></p>
              <a href="<%= buttonLink %>" class="btn btn-success mt-3"><%= buttonText %></a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('config/footer') %>
  </div>
</body>

</html>
